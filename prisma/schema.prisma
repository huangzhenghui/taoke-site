generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  seoTitle       String
  seoDescription String
  sortOrder      Int
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([sortOrder])
}

model Product {
  id             String   @id @default(cuid())
  platform       String
  source         String
  outerItemId    String
  title          String
  shortTitle     String
  description    String
  mainImage      String
  price          Decimal  @db.Decimal(12, 2)
  finalPrice     Decimal  @db.Decimal(12, 2)
  couponAmount   Decimal  @db.Decimal(12, 2)
  commissionRate Decimal  @db.Decimal(6, 2)
  shopName       String
  categoryId     String
  categorySlug   String
  categoryName   String
  promotionUrl   String
  couponUrl      String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([platform, outerItemId])
  @@index([categoryId])
  @@index([categorySlug])
  @@index([status])
  @@index([source])
}

model Article {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  summary           String
  content           String
  coverImage        String
  categoryId        String
  categoryName      String
  tags              Json
  relatedProductIds Json
  status            String
  publishedAt       DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}

model SeoPage {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  description       String
  h1                String
  intro             String
  keywords          Json
  categoryId        String
  categoryName      String
  relatedProductIds Json
  relatedArticleIds Json
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

model PromotionLink {
  id                  String   @id @default(cuid())
  productId           String
  platform            String
  source              String
  outerItemId         String
  promotionUrl        String
  couponUrl           String
  tpwd                String
  raw                 Json?
  promotionPositionId String
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([productId])
  @@index([platform, outerItemId])
  @@index([source])
  @@index([status])
}

model ApiSource {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String
  status    String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model SyncLog {
  id           String    @id @default(cuid())
  source       String
  taskType     String
  status       String
  message      String?
  totalCount   Int
  successCount Int
  failedCount  Int
  startedAt    DateTime
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([taskType])
  @@index([status])
  @@index([startedAt])
}
