generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([sortOrder])
}

model Product {
  id                   String          @id @default(cuid())
  source               String
  outerItemId          String
  dataokeId            String?
  goodsSign            String?
  title                String
  shortTitle           String?
  description          String?
  mainImage            String?
  images               Json?
  platform             String
  shopName             String?
  shopLogo             String?
  brandName            String?
  brandId              String?
  price                Decimal?        @db.Decimal(12, 2)
  finalPrice           Decimal?        @db.Decimal(12, 2)
  couponAmount         Decimal?        @db.Decimal(12, 2)
  couponConditions     String?
  commissionRate       Decimal?        @db.Decimal(6, 2)
  monthSales           Int?
  dailySales           Int?
  twoHoursSales        Int?
  couponStartTime      DateTime?
  couponEndTime        DateTime?
  couponTotalNum       Int?
  couponReceiveNum     Int?
  couponRemainCount    Int?
  categoryId           String?
  categorySlug         String?
  categoryName         String?
  sourceCid            String?
  sourceSubcid         String?
  promotionUrl         String?
  couponUrl            String?
  status               String
  isManualHidden       Boolean         @default(false)
  isManualEdited       Boolean         @default(false)
  manualCategoryLocked Boolean         @default(false)
  lastSyncedAt         DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  promotionLinks       PromotionLink[]

  @@unique([source, outerItemId])
  @@index([categoryId])
  @@index([categorySlug])
  @@index([status])
  @@index([source])
  @@index([sourceCid])
  @@index([lastSyncedAt])
  @@index([couponEndTime])
}

model Article {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  summary           String
  content           String
  coverImage        String
  categoryId        String
  categoryName      String
  tags              Json
  relatedProductIds Json
  status            String
  publishedAt       DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}

model SeoPage {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  description       String
  h1                String
  intro             String
  keywords          Json
  categoryId        String
  categoryName      String
  relatedProductIds Json
  relatedArticleIds Json
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

model PromotionLink {
  id                String    @id @default(cuid())
  productId         String
  source            String
  outerItemId       String
  platform          String
  promotionUrl      String?
  couponUrl         String?
  shortUrl          String?
  tpwd              String?
  longTpwd          String?
  maxCommissionRate Decimal?  @db.Decimal(6, 2)
  minCommissionRate Decimal?  @db.Decimal(6, 2)
  originalPrice     Decimal?  @db.Decimal(12, 2)
  actualPrice       Decimal?  @db.Decimal(12, 2)
  couponStartTime   DateTime?
  couponEndTime     DateTime?
  couponInfo        String?
  couponTotalCount  Int?
  couponRemainCount Int?
  status            String
  lastGeneratedAt   DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  product           Product   @relation(fields: [productId], references: [id])

  @@unique([productId, source])
  @@index([outerItemId])
  @@index([source])
  @@index([status])
  @@index([expiresAt])
}

model SourceCategoryMapping {
  id            String   @id @default(cuid())
  source        String
  sourceCid     String
  sourceSubcid  String?
  sourceName    String?
  sourceSubName String?
  categoryId    String
  categorySlug  String
  confidence    String
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([source, sourceCid, sourceSubcid])
  @@index([source])
  @@index([categorySlug])
  @@index([status])
}

model ApiSource {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String
  status    String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model SyncLog {
  id           String    @id @default(cuid())
  source       String
  taskType     String
  status       String
  params       Json?
  startedAt    DateTime
  finishedAt   DateTime?
  totalCount   Int       @default(0)
  successCount Int       @default(0)
  createdCount Int       @default(0)
  updatedCount Int       @default(0)
  skippedCount Int       @default(0)
  failedCount  Int       @default(0)
  message      String?
  errorSummary String?
  createdAt    DateTime  @default(now())

  @@index([source])
  @@index([taskType])
  @@index([status])
  @@index([startedAt])
}
